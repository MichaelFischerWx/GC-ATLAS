# Local data cache (ERA5 NetCDFs, intermediate Zarr, logs)
data/*
# …except small static assets the frontend fetches (climate indices
# for the composite builder, regenerated by pipeline/update_indices.py).
!data/indices.json
*.nc
*.nc4
*.grib
*.zarr/
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# CDS / cloud credentials (should live in $HOME; guard anyway)
.cdsapirc
deploy.env
*.key.json
service-account*.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Node (for any future build tooling, kept defensive)
node_modules/

# Personal notes / drafts (kept locally, not part of the repo)
docs/
